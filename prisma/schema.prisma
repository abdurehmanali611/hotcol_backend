generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id        Int     @id @default(autoincrement())
  UserName  String  @unique
  Password  String
  HotelName String
  Role      String
  LogoUrl   String?
}

model Item {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  category  String
  type      String
  HotelName String
  imageUrl  String
  createdAt DateTime @default(now())
}

model cashouts {
  id             Int      @id @default(autoincrement())
  items          Json
  prices         Json
  measuredBy     Json
  requiredAmount Json
  totalCalc      Float
  HotelName      String
  createdAt      DateTime @default(now())
}

model Order {
  id          Int      @id @default(autoincrement())
  title       String
  imageUrl    String
  tableNo     Int
  category    String
  type        String
  orderAmount Int
  HotelName   String
  price       Float
  waiterName  String
  status      String?
  payment     String?
  withBank    Boolean?
  credit      Boolean?
  credittorName String?
  creditAmount  Float?
  createdAt   DateTime @default(now())
}

model waiter {
  id           Int      @id @default(autoincrement())
  name         String
  HotelName    String
  sex          String
  age          Int
  experience   Int
  phoneNumber  String
  price        Json     @default("[]")
  tablesServed Json     @default("[]")
  payment      Json     @default("[]")
  createdAt    DateTime @default(now())
}

model table {
  id        Int      @id @default(autoincrement())
  tableNo   Int
  capacity  Int
  price     Json     @default("[]")
  payment   Json     @default("[]")
  HotelName String
  createdAt DateTime @default(now())
}

model creditLevel {
  id           Int      @id @default(autoincrement())
  level        String
  requiredAmount Float
  timeInterval  Int
  timeFrame       String
  HotelName    String
}

model pityCash {
  id        Int      @id @default(autoincrement())
  amount    Float
  startDate DateTime
  endDate   DateTime
  HotelName String
}

model CreditRegistration {
  id           Int      @id @default(autoincrement())
  imageUrl     String
  name         String
  sex          String
  creditLevel  String
  phoneNumber  String
  amount       Float
  timeInterval Int
  timeFrame    String
  paidAmount   Float
  registrationDate DateTime @default(now())
  HotelName    String
}

model ItemRegistration {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  name      String
  level     String
  buyingDate DateTime @default(now())
  expireDate DateTime
  amount    Int
  supplier   String
  status     String?
  statusBy   String?
  measuredBy String
  price     Float
  HotelName String
}
