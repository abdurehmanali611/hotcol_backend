generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id           Int     @id @default(autoincrement())
  UserName     String  @unique
  Password     String
  /// Display / marketing business name (not necessarily unique)
  HotelName    String
  /// Tenant id shared by all staff (10-digit TIN or 11–12 digits); matches Item/Order.HotelName — not unique per row
  tinNumber    String?
  businessType String?
  modules      Json?
  Role         String
  LogoUrl      String?

  @@index([tinNumber])
}

model Item {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  category  String
  type      String
  HotelName String
  imageUrl  String
  createdAt DateTime @default(now())
}

model cashouts {
  id             Int      @id @default(autoincrement())
  items          Json
  prices         Json
  measuredBy     Json
  requiredAmount Json
  totalCalc      Float
  HotelName      String
  createdAt      DateTime @default(now())
}

model Order {
  id          Int      @id @default(autoincrement())
  title       String
  imageUrl    String
  tableNo     Int
  category    String
  type        String
  orderAmount Int
  HotelName   String
  price       Float
  waiterName  String
  status      String?
  payment     String?
  withBank    Boolean?
  credit      Boolean?
  credittorName String?
  creditAmount  Float?
  createdAt   DateTime @default(now())
}

model waiter {
  id           Int      @id @default(autoincrement())
  name         String
  HotelName    String
  sex          String
  age          Int
  experience   Int
  phoneNumber  String
  price        Json     @default("[]")
  tablesServed Json     @default("[]")
  payment      Json     @default("[]")
  incomeAt     Json     @default("[]")
  createdAt    DateTime @default(now())
}

model table {
  id        Int      @id @default(autoincrement())
  tableNo   Int
  capacity  Int
  price     Json     @default("[]")
  payment   Json     @default("[]")
  incomeAt  Json     @default("[]")
  HotelName String
  createdAt DateTime @default(now())
}

model creditLevel {
  id           Int      @id @default(autoincrement())
  level        String
  requiredAmount Float
  timeInterval  Int
  timeFrame       String
  HotelName    String
}

model pityCash {
  id        Int      @id @default(autoincrement())
  amount    Float
  startDate DateTime
  endDate   DateTime
  HotelName String
}

model CreditRegistration {
  id                 Int       @id @default(autoincrement())
  imageUrl           String
  name               String
  sex                String
  creditLevel        String
  phoneNumber        String
  amount             Float
  timeInterval       Int
  timeFrame          String
  paidAmount         Float
  registrationDate   DateTime  @default(now())
  HotelName          String
  registrantType     String    @default("STAFF")
  approvalStatus     String    @default("AUTHORIZED")
  companyTinNumber   String    @default("")
  affiliatedCompany  String    @default("")
  rejectionReason    String?
  adminActorName     String?
  adminAuthorizedAt  DateTime?
}

/// Per-hotel voucher sequence counters (purchase request, item registration, stock movement).
model HotelVoucherCounter {
  id          Int    @id @default(autoincrement())
  HotelName   String
  voucherType String
  lastNumber  Int    @default(0)

  @@unique([HotelName, voucherType])
  @@index([HotelName])
}

model ItemRegistration {
  id                Int      @id @default(autoincrement())
  name              String
  imageUrl          String
  category          String
  amount            Float
  measuredBy        String
  unitPrice         Float
  registrationDate  DateTime 
  expireDate        DateTime
  supplierName      String
  supplierPhone     String
  Address           String
  /// When true, unit price / line totals were agreed including VAT.
  purchaseWithVat   Boolean  @default(false)
  supplierTinNumber String   @default("")
  paidAmount        Float
  HotelName         String
  /// Per-hotel sequential voucher (display padded to 4+ digits).
  voucherNumber     Int?
  /// Linked purchase request voucher when goods are received against a PR.
  purchaseRequestId Int?
  /// PENDING_CC | CHECKED_CC | PENDING_FINANCE | PENDING_MANAGER | AUTHORIZED | REJECTED_* | VOID
  approvalStatus    String   @default("PENDING_CC")
  ccProfileId       Int?
  ccActorName       String?
  ccCheckedAt       DateTime?
  financeActorName  String?
  financeApprovedAt DateTime?
  managerActorName  String?
  managerAuthorizedAt DateTime?
  rejectionReason   String?
  /// Unit price revision after initial authorization (same 3-tier flow as purchase requests).
  pendingUnitPrice    Float?
  unitPriceChangeStatus String?

  @@index([HotelName])
  @@index([approvalStatus])
}

model ItemStatus {
  id           Int      @id @default(autoincrement())
  name         String
  imageUrl     String
  category     String
  amount       Float
  measuredBy   String
  unitPrice    Float
  actionDate   DateTime
  supplierName String
  supplierPhone String
  Address       String
  purchaseWithVat   Boolean  @default(false)
  supplierTinNumber String   @default("")
  paidAmount     Float
  status         String
  statusBy       String
  HotelName      String
  /// Stock movement voucher when created from an approved hotel stock-out request.
  voucherNumber     Int?
  stockOutRequestId Int?

  @@index([HotelName])
  @@index([stockOutRequestId])
}

/// Named individuals sharing the Cost Control login — selected when approving.
model CostControllerProfile {
  id          Int      @id @default(autoincrement())
  displayName String
  HotelName   String
  createdAt   DateTime @default(now())

  @@index([HotelName])
}

/// Store requests to buy items not currently in stock. CC check → Finance approve → Manager authorize.
model PurchaseRequest {
  id                  Int       @id @default(autoincrement())
  HotelName           String
  itemName            String
  quantity            Float
  measuredBy          String
  notes               String    @default("")
  estimatedUnitPrice  Float     @default(0)
  supplierName        String    @default("")
  supplierPhone       String    @default("")
  category            String    @default("Others")
  /// PENDING_CC | CHECKED_CC | PENDING_FINANCE | PENDING_MANAGER | AUTHORIZED | REJECTED_* | legacy APPROVED_FINANCE
  status              String
  storeUserName       String
  voucherNumber       Int?
  ccProfileId         Int?
  ccActorName         String?
  ccApprovedAt        DateTime?
  financeActorName    String?
  financeApprovedAt   DateTime?
  managerActorName    String?
  managerAuthorizedAt DateTime?
  rejectionReason     String?
  /// Unit price revision after initial approval (same 3-tier flow).
  pendingUnitPrice    Float?
  unitPriceChangeStatus String?
  createdAt           DateTime  @default(now())

  @@index([HotelName])
  @@index([status])
}

/// Hotel store movements: CC check → Finance approve → Manager authorize → inventory update.
model StockOutRequest {
  id                   Int      @id @default(autoincrement())
  HotelName            String
  itemRegistrationId   Int
  /// Item name when this request was created (kept if the stock row is removed later).
  itemNameSnapshot     String   @default("")
  /// STOCK_OUT | WASTAGE | RETURN_SUPPLIER
  movementType         String
  amount               Float
  stakeHolderOrReason  String
  /// PENDING_CC | CHECKED_CC | PENDING_FINANCE | PENDING_MANAGER | APPROVED | REJECTED | legacy PENDING
  status               String
  voucherNumber        Int?
  requestedByUserName  String
  ccProfileId          Int?
  ccActorName          String?
  ccCheckedAt          DateTime?
  financeActorName     String?
  financeApprovedAt    DateTime?
  managerActorName     String?
  managerAuthorizedAt  DateTime?
  decidedAt            DateTime?
  rejectionReason      String?
  createdAt            DateTime @default(now())

  @@index([HotelName])
  @@index([status])
}

/// Daily chef / bar count rows (opening pulse, documented stock-out, closing on-hand).
/// Implied movement for a day is derived when the next day’s opening is recorded: opening + stockOut − nextOpening.
model KitchenBarBeginning {
  id          Int      @id @default(autoincrement())
  HotelName   String
  /// CHEF | BAR
  station     String
  itemName    String
  /// Opening pulse — count at the start of calendarDate (same unit as inventory).
  amount      Float
  measuredBy  String
  /// YYYY-MM — kept in sync with calendarDate for reporting and sync jobs.
  monthPeriod String
  /// YYYY-MM-DD — one logical row per station + item + day.
  calendarDate   String   @default("")
  /// Units issued / logged out that day (usage trail).
  stockOutDay    Float    @default(0)
  /// Units issued from station stock to management in that day.
  managementTakenDay Float @default(0)
  /// Physical on-hand at end of day (lights-out snapshot).
  closingOnHand  Float    @default(0)
  notes       String   @default("")
  createdAt   DateTime @default(now())

  @@index([HotelName])
  @@index([monthPeriod])
  @@index([calendarDate])
  @@index([HotelName, station, itemName, calendarDate])
}

/// Rolled-up figures after “Sync monthly inventory” from daily rows for a month.
model KitchenBarMonthlySnapshot {
  id                   Int      @id @default(autoincrement())
  HotelName            String
  station              String
  itemName             String
  monthPeriod          String
  /// Sum of implied daily movement units for that month (excludes the anchor day).
  totalImpliedSales    Float    @default(0)
  /// closingOnHand from the last calendar day present in that month for this key.
  lastDayClosingOnHand Float    @default(0)
  syncedAt             DateTime @default(now())

  @@unique([HotelName, station, itemName, monthPeriod])
  @@index([HotelName])
  @@index([monthPeriod])
}

/// Manager-defined tier (ceiling + period) for hotel corporate credit — cashier picks one per company.
model HotelCorporateCreditTier {
  id            Int      @id @default(autoincrement())
  HotelName     String
  name          String
  creditCeiling Float
  timeInterval  Int
  timeFrame     String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  companies HotelCreditCompany[]

  @@index([HotelName])
}

/// Corporate credit account registered by hotel cashier (B2B meals).
model HotelCreditCompany {
  id              Int      @id @default(autoincrement())
  HotelName       String
  companyName     String
  companyTinNumber String  @default("")
  contactName     String   @default("")
  phoneNumber     String   @default("")
  email           String   @default("")
  /// NOW | AFTER_SERVICE — pay before or after receiving meals.
  payTiming       String   @default("AFTER_SERVICE")
  /// PENDING_MANAGER | AUTHORIZED | REJECTED
  approvalStatus  String   @default("PENDING_MANAGER")
  managerActorName String?
  managerAuthorizedAt DateTime?
  rejectionReason String?
  /// Snapshot label from the tier at registration time.
  creditLevel     String
  /// Money ceiling for the deal window (same spirit as cafe credit amount).
  creditLimit     Float
  timeInterval    Int
  timeFrame       String
  hotelCorporateCreditTierId Int?
  tier            HotelCorporateCreditTier? @relation(fields: [hotelCorporateCreditTierId], references: [id], onDelete: SetNull)
  /// JSON: [{ "name": "...", "itemId"?: number }]
  allowedMenuJson String   @db.Text
  dealNotes       String   @default("")
  imageUrl        String   @default("")
  /// Presale / amount paid upfront when payTiming is NOW.
  paidAmount      Float    @default(0)
  createdAt       DateTime @default(now())

  parties      HotelCreditParty[]
  consumptions HotelCreditConsumption[]

  @@index([HotelName])
  @@index([hotelCorporateCreditTierId])
  @@index([approvalStatus])
}

/// Staff or guest registered under a company account.
model HotelCreditParty {
  id          Int      @id @default(autoincrement())
  HotelName   String
  companyId   Int
  displayName String
  phoneNumber String   @default("")
  sex         String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())

  company      HotelCreditCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consumptions HotelCreditConsumption[]

  @@index([HotelName])
  @@index([companyId])
}

/// One consumption event (timestamped for reporting); not visible to hotel store role in UI.
model HotelCreditConsumption {
  id          Int      @id @default(autoincrement())
  HotelName   String
  companyId   Int
  partyId     Int
  /// JSON array: [{ "name": "", "qty": 1, "unitPrice": 0 }]
  linesJson   String   @db.Text
  totalAmount Float
  occurredAt  DateTime @default(now())
  recordedBy  String

  company HotelCreditCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  party   HotelCreditParty   @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([HotelName])
  @@index([companyId])
  @@index([occurredAt])
}
